# ==============================================================================
# Phoenix - Environment Configuration
# ==============================================================================
# Copy this file to .env and fill in the actual values.
# Never commit your real .env file. It is in .gitignore.
# ==============================================================================

# ----- Google Cloud -----
# Get your project ID from the Google Cloud Console.
GCP_PROJECT_ID=your-project-id-here

# Region for all services.
# - us-central1: default, best Vertex AI support, fastest model availability
# - asia-southeast2 (Jakarta): closer for Indonesian developers, Agent Engine supported,
#   but not all Gemini models available. Fall back to us-central1 if your model is missing.
GCP_REGION=us-central1

# Path to your service account JSON key, used for local development only.
# In Cloud Run, the runtime service account is used automatically.
GOOGLE_APPLICATION_CREDENTIALS=./secrets/service-account.json

# ----- Vertex AI / Gemini -----
# The Gemini model to use. Flash is faster and cheaper, Pro is more capable.
# Gemini 2.0 Flash will shut down on June 1, 2026. Use gemini-3-flash or newer.
GEMINI_MODEL=gemini-3-flash

# Vertex AI Agent Builder location.
# Available in: us-central1, asia-southeast2 (Jakarta), europe-west6, asia-east2,
# asia-northeast3 (Seoul), northamerica-northeast2, southamerica-east1.
AGENT_BUILDER_LOCATION=us-central1

# ----- GitLab Integration -----
# Personal access token with `api` scope. Create one at:
# https://gitlab.com/-/user_settings/personal_access_tokens
GITLAB_TOKEN=glpat-your-token-here

# GitLab instance URL. Use https://gitlab.com for the public instance.
GITLAB_BASE_URL=https://gitlab.com

# Webhook secret for verifying incoming GitLab webhooks.
# Generate with: openssl rand -hex 32
GITLAB_WEBHOOK_SECRET=change-me-to-a-random-string

# ----- Phoenix Agent Behavior -----
# Minimum confidence score (0.0 to 1.0) for the agent to act autonomously.
# Below this, the agent escalates to a human instead.
AGENT_CONFIDENCE_THRESHOLD=0.7

# Maximum number of fix strategies to try before giving up.
MAX_RETRY_STRATEGIES=3

# Timeout for sandbox execution in seconds.
SANDBOX_TIMEOUT_SECONDS=300

# ----- Service Ports (local development) -----
GATEWAY_PORT=8080
AGENT_PORT=8000
PARSER_PORT=8001
WEB_PORT=5173

# ----- Firestore -----
# Collection name prefix. Useful if you want to separate dev and prod data.
FIRESTORE_COLLECTION_PREFIX=phoenix

# ----- Logging -----
# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
