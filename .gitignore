# Secrets and environment
.env
.env.local
.env.*.local
secrets/
*.pem
*.key
service-account*.json

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
.venv/
venv/
ENV/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Go
*.test
*.out
vendor/
go.work

# Rust
target/
Cargo.lock
**/*.rs.bk

# Node / TypeScript
node_modules/
.next/
.nuxt/
.cache/
.parcel-cache/
.vite/
dist/
build/
*.tsbuildinfo

# Editor
.vscode/
.idea/
*.swp
*.swo
*.swn
.DS_Store
Thumbs.db

# Docker
.docker/

# Logs
*.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Coverage
coverage/
.nyc_output/
htmlcov/
.coverage
.coverage.*

# Terraform
*.tfstate
*.tfstate.*
.terraform/
.terraform.lock.hcl

# Temporary files
tmp/
temp/
*.tmp
